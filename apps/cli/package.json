{
  "name": "@tray-link/cli",
  "private": true,
  "version": "2.0.0",
  "description": "The command-line tool used by Tray Link",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "cli": "node ./dist/index.js",
    "build": "tsc",
    "archive": "yarn build && pkg dist/index.js --config pkg.config.json -o dist/tlink",
    "watch": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@tray-link/common-types": "workspace:*",
    "@tray-link/tray-shared": "workspace:*",
    "commander": "^10.0.1",
    "electron-store": "^11.0.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "pkg": "^5.8.1",
    "ts-jest": "^29.3.4",
    "typescript": "^5.5.4"
  }
}
