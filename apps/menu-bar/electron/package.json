{
  "name": "@tray-link/electron",
  "version": "2.1.4",
  "productName": "TrayLink",
  "description": "An app to manage your projects from the system tray",
  "license": "MIT",
  "private": true,
  "main": ".vite/build/main.js",
  "scripts": {
    "prestart": "node scripts/prestart.js",
    "start": "electron-forge start",
    "dev": "node scripts/prestart.js && electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-deb": "^7.5.0",
    "@electron-forge/maker-rpm": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.5.0",
    "@electron-forge/plugin-vite": "^7.5.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/express": "^4.17.21",
    "electron": "33.2.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.12",
    "vite-plugin-static-copy": "^2.1.0"
  },
  "dependencies": {
    "@tray-link/common-types": "workspace:*",
    "@tray-link/rn-electron-modules": "workspace:*",
    "@tray-link/tray-shared": "workspace:*",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "express": "^4.18.2"
  }
}
