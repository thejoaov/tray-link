{
  "name": "@tray-link/tray-link",
  "version": "2.1.0",
  "private": true,
  "packageManager": "bun@1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "apps/menu-bar/electron",
    "apps/menu-bar/modules/*"
  ],
  "scripts": {
    "cli": "cd apps/cli && bun run cli",
    "dev": "turbo run dev --filter=@tray-link/menu-bar --filter=@tray-link/electron",
    "dev:macos": "turbo run dev:macos --filter=@tray-link/menu-bar",
    "build": "turbo run build",
    "lint": "biome check .",
    "typecheck": "turbo run typecheck",
    "macos": "cd apps/menu-bar && bun run macos",
    "electron:package": "cd apps/menu-bar && bun run export:web && cd electron && bun run make",
    "postinstall": "patch-package && lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "lefthook": "2.1.2",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "turbo": "2.8.12",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
